# DeepLX 服务配置
DEEPLX_URL=your_deeplx_url_here
DEEPLX_TOKEN=your_access_token_here

# 服务端口
SERVER_PORT=9448
BACKEND_PORT=8449
FRONTEND_PORT=9449

# 服务TOKEN
AUTH_TOKEN=your_auth_token_here

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 文件清理配置
CLEANUP_INTERVAL=1h
FILE_MAX_AGE=24h
UPLOAD_MAX_SIZE=1073741824

# 日志配置
LOG_PATH=./logs
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
